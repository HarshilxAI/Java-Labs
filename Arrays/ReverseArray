public class ReverseArray{
    public static void main(String [] args){
    int arr [] = {10,20,30,40,50};
    int left = 0; 
    int right = arr.length-1;
    
    while(right>left){
        int temp = arr[left];
        arr[left] = arr[right];
        arr[right] = temp;
        
        left++;
        right--;
    }
    for (int i=0; i<arr.length; i++){
        System.out.println(arr[i] );
    }
}}
